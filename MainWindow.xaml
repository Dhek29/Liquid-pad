<Window x:Class="UsersFile.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UsersFile" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1A1A2E" BorderBrush="#2D2D3D" BorderThickness="0,0,1,0">
            <StackPanel>
                <!-- Header -->
                <Border Background="#16213E" Height="60" Padding="20">
                    <TextBlock Text="✍️ UsersFile" FontSize="18" FontWeight="Bold" Foreground="#4ECDC4" VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,15">
                        <!-- FILE SECTION -->
                        <TextBlock Text="FILE" Foreground="#6C6C8A" FontSize="10" Margin="20,0,0,10"/>
                        <Button x:Name="NewBtn" Content="📄 New File" Click="NewFile_Click" Style="{StaticResource NavButton}"/>
                        <Button x:Name="OpenBtn" Content="📂 Open File" Click="OpenFile_Click" Style="{StaticResource NavButton}"/>
                        <Button x:Name="SaveBtn" Content="💾 Save File" Click="SaveFile_Click" Style="{StaticResource NavButton}"/>
                        
                        <Separator Margin="15,15" Background="#2D2D3D"/>

                        <!-- NAVIGATION SECTION (Top Left Icons) -->
                        <TextBlock Text="NAVIGATION" Foreground="#6C6C8A" FontSize="10" Margin="20,0,0,10"/>
                        
                        <WrapPanel Margin="15,0">
                            <Button x:Name="UndoBtn" Content="↩️" Click="Undo_Click" Width="45" Height="35" Margin="5" Style="{StaticResource IconButton}" ToolTip="Undo (Ctrl+Z)"/>
                            <Button x:Name="RedoBtn" Content="↪️" Click="Redo_Click" Width="45" Height="35" Margin="5" Style="{StaticResource IconButton}" ToolTip="Redo (Ctrl+Y)"/>
                            <Button x:Name="CopyBtn" Content="📋" Click="Copy_Click" Width="45" Height="35" Margin="5" Style="{StaticResource IconButton}" ToolTip="Copy (Ctrl+C)"/>
                            <Button x:Name="CutBtn" Content="✂️" Click="Cut_Click" Width="45" Height="35" Margin="5" Style="{StaticResource IconButton}" ToolTip="Cut (Ctrl+X)"/>
                            <Button x:Name="PasteBtn" Content="📌" Click="Paste_Click" Width="45" Height="35" Margin="5" Style="{StaticResource IconButton}" ToolTip="Paste (Ctrl+V)"/>
                        </WrapPanel>

                        <Separator Margin="15,15" Background="#2D2D3D"/>

                        <!-- FORMAT SECTION -->
                        <TextBlock Text="FORMAT" Foreground="#6C6C8A" FontSize="10" Margin="20,0,0,10"/>
                        <Button x:Name="UpperBtn" Content="🔠 UPPERCASE" Click="ToUpper_Click" Style="{StaticResource NavButton}"/>
                        <Button x:Name="LowerBtn" Content="🔡 lowercase" Click="ToLower_Click" Style="{StaticResource NavButton}"/>

                        <Separator Margin="15,15" Background="#2D2D3D"/>

                        <!-- THEME SECTION -->
                        <TextBlock Text="THEME" Foreground="#6C6C8A" FontSize="10" Margin="20,0,0,10"/>
                        
                        <RadioButton x:Name="DarkThemeRadio" Content="🌙 Dark Mode" GroupName="Theme" 
                                     Margin="20,5" Foreground="#E0E0E0" Checked="DarkTheme_Checked"/>
                        
                        <RadioButton x:Name="LightThemeRadio" Content="☀️ Light Mode" GroupName="Theme" 
                                     Margin="20,5" Foreground="#E0E0E0" Checked="LightTheme_Checked"/>
                        
                        <RadioButton x:Name="BlurThemeRadio" Content="✨ Blur Mode (Wallpaper)" GroupName="Theme" 
                                     Margin="20,5" Foreground="#E0E0E0" Checked="BlurTheme_Checked"/>

                        <Separator Margin="15,15" Background="#2D2D3D"/>

                        <!-- SETTINGS SECTION -->
                        <TextBlock Text="SETTINGS" Foreground="#6C6C8A" FontSize="10" Margin="20,0,0,10"/>
                        <Button x:Name="SettingsBtn" Content="⚙️ Settings" Click="OpenSettings" Style="{StaticResource NavButton}"/>

                        <Separator Margin="15,15" Background="#2D2D3D"/>

                        <!-- STATISTICS -->
                        <Border Background="#16213E" CornerRadius="10" Margin="15" Padding="12">
                            <StackPanel>
                                <TextBlock Text="📊 STATISTICS" Foreground="#6C6C8A" FontSize="10" Margin="0,0,0,10"/>
                                <TextBlock x:Name="StatsWords" Text="Words: 0" Foreground="#E0E0E0" FontSize="11" Margin="0,3"/>
                                <TextBlock x:Name="StatsChars" Text="Characters: 0" Foreground="#E0E0E0" FontSize="11" Margin="0,3"/>
                                <TextBlock x:Name="StatsLines" Text="Lines: 0" Foreground="#E0E0E0" FontSize="11" Margin="0,3"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="#16213E" BorderBrush="#2D2D3D" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock x:Name="FileNameText" Text="Untitled" FontSize="14" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                        <TextBlock x:Name="ModifiedIndicator" Text="●" Foreground="#4ECDC4" FontSize="10" Margin="8,0,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Button x:Name="SearchBtn" Click="Find_Click" Style="{StaticResource TopButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="14"/>
                                <TextBlock Text=" Search" Margin="5,0,0,0" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- EDITOR -->
            <TextBox x:Name="Editor" Grid.Row="1"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     Background="#1E1E2E"
                     Foreground="#E0E0E0"
                     FontFamily="Consolas"
                     FontSize="13"
                     BorderThickness="0"
                     Padding="20"
                     CaretBrush="#4ECDC4"
                     SelectionBrush="#4ECDC4"
                     SelectionOpacity="0.3"
                     TextChanged="Editor_TextChanged"
                     SelectionChanged="Editor_SelectionChanged"
                     PreviewKeyDown="Editor_PreviewKeyDown"/>

            <!-- STATUS BAR -->
            <Border Grid.Row="2" Background="#16213E" BorderBrush="#2D2D3D" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="StatusText" Text="Ready" Foreground="#6C6C8A" FontSize="11" VerticalAlignment="Center" Margin="20,0"/>
                    <TextBlock x:Name="CursorText" Text="Ln 1, Col 1" Foreground="#6C6C8A" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
