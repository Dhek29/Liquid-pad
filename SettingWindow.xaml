<Window x:Class="UsersFile.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Settings" Height="450" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <!-- Theme Selection -->
        <TextBlock Grid.Row="1" Text="🎨 Theme" FontWeight="Bold" FontSize="14" Foreground="#34495E" Margin="0,0,0,5"/>
        <ComboBox x:Name="ThemeBox" Grid.Row="2" Margin="0,0,0,15" Height="35" FontSize="13">
            <ComboBoxItem Content="🌙 Dark"/>
            <ComboBoxItem Content="☀️ Light"/>
            <ComboBoxItem Content="✨ Blur"/>
        </ComboBox>

        <!-- Font Selection -->
        <TextBlock Grid.Row="3" Text="🔤 Font" FontWeight="Bold" FontSize="14" Foreground="#34495E" Margin="0,0,0,5"/>
        <ComboBox x:Name="FontBox" Grid.Row="4" Margin="0,0,0,15" Height="35" FontSize="13">
            <ComboBoxItem Content="Consolas"/>
            <ComboBoxItem Content="Calibri"/>
            <ComboBoxItem Content="Arial"/>
            <ComboBoxItem Content="Times New Roman"/>
            <ComboBoxItem Content="Verdana"/>
            <ComboBoxItem Content="Courier New"/>
            <ComboBoxItem Content="Segoe UI"/>
            <ComboBoxItem Content="Roboto"/>
        </ComboBox>

        <!-- Font Size -->
        <TextBlock Grid.Row="5" Text="📏 Font Size" FontWeight="Bold" FontSize="14" Foreground="#34495E" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="6" Margin="0,0,0,15">
            <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="72" Value="14" TickFrequency="2" IsSnapToTickEnabled="True"/>
            <TextBlock x:Name="FontSizeValue" Text="14" HorizontalAlignment="Center" Margin="0,5,0,0" FontWeight="Bold"/>
        </StackPanel>

        <!-- Preview -->
        <Border Grid.Row="7" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20" Background="#F8F9FA">
            <TextBlock x:Name="PreviewText" Text="The quick brown fox jumps over the lazy dog" FontSize="14" TextWrapping="Wrap"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Width="100" Height="35" Margin="0,0,10,0" Click="Cancel_Click" Background="#E74C3C" Foreground="White" Cursor="Hand"/>
            <Button Content="Apply" Width="100" Height="35" Click="ApplySettings" Background="#27AE60" Foreground="White" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
