<Window x:Class="UsersFile.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="280" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252526">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,25"/>
        
        <TextBlock Grid.Row="1" Text="Font Size" Foreground="#CCCCCC" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="FontSizeSlider" Grid.Column="0" Minimum="8" Maximum="72" Value="13" TickFrequency="2" IsSnapToTickEnabled="True"/>
            <TextBlock x:Name="FontSizeValue" Grid.Column="1" Text="13" Foreground="#4EC9B0" FontSize="14" FontWeight="Bold" Margin="15,0,0,0" VerticalAlignment="Center"/>
        </Grid>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button Content="Cancel" Click="CancelButton_Click" Width="80" Height="32" Margin="0,0,10,0" 
                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Apply" Click="ApplyButton_Click" Width="80" Height="32" 
                    Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
