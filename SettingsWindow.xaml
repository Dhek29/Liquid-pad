<Window x:Class="UsersFile.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Theme" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
        <ComboBox x:Name="ThemeBox" Grid.Row="2" Margin="0,0,0,15" Height="35">
            <ComboBoxItem Content="Dark"/>
            <ComboBoxItem Content="Light"/>
            <ComboBoxItem Content="Blur"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Text="Font" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
        <ComboBox x:Name="FontBox" Grid.Row="4" Margin="0,0,0,15" Height="35">
            <ComboBoxItem Content="Consolas"/>
            <ComboBoxItem Content="Calibri"/>
            <ComboBoxItem Content="Arial"/>
            <ComboBoxItem Content="Times New Roman"/>
            <ComboBoxItem Content="Verdana"/>
        </ComboBox>

        <TextBlock Grid.Row="5" Text="Font Size" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
        <Slider x:Name="FontSizeSlider" Grid.Row="6" Minimum="8" Maximum="72" Value="14" TickFrequency="2" Margin="0,0,0,15"/>
        <TextBlock x:Name="FontSizeValue" Text="14" Grid.Row="6" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-5"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="80" Height="35" Margin="0,0,10,0" Click="Cancel_Click" Background="#E74C3C"/>
            <Button Content="Apply" Width="80" Height="35" Click="ApplySettings" Background="#27AE60"/>
        </StackPanel>
    </Grid>
</Window>
